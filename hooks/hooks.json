{
  "hooks": {
    "SessionStart":      [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "SessionEnd":        [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "UserPromptSubmit":  [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "PreToolUse":        [{ "hooks": [
      { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 },
      { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/approve-hook.mjs\"", "timeout": 120 }
    ] }],
    "PostToolUse":       [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "PostToolUseFailure":[{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "SubagentStart":     [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "SubagentStop":      [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "Notification":      [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "PreCompact":        [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }],
    "Stop":              [{ "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/forwarder.mjs\"", "timeout": 3 }] }]
  }
}
